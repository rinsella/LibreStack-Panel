APP_NAME="LibreStack Panel"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Default: SQLite for the easiest possible install.
DB_CONNECTION=sqlite
# To use MySQL/MariaDB instead, set DB_CONNECTION=mysql and fill the values below.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=librestack
# DB_USERNAME=librestack
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Cookies are sent only over HTTPS. Set to true once the panel is served over
# HTTPS (recommended for production). Leave false only for local HTTP testing.
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="panel@localhost"
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# LibreStack Panel specific settings
# ----------------------------------------------------------------------------
# Master switch used by the first-run setup wizard.
LIBRESTACK_SETUP_COMPLETED=false

# Base directories used by the panel on the server.
LIBRESTACK_WEB_ROOT=/home
LIBRESTACK_BACKUP_PATH=/var/lib/librestack/backups
LIBRESTACK_NGINX_AVAILABLE=/etc/nginx/sites-available
LIBRESTACK_NGINX_ENABLED=/etc/nginx/sites-enabled
LIBRESTACK_LOG_PATH=/var/log/librestack

# Default PHP version used when generating PHP-FPM site configs.
LIBRESTACK_DEFAULT_PHP=8.3

# Set to true on a real Linux server. When false (local/dev) the panel will not
# attempt to execute privileged system commands and will degrade gracefully.
LIBRESTACK_SYSTEM_ENABLED=false

# When true, privileged binaries (systemctl, nginx, certbot, ufw, chown, chmod,
# mysql, mysqldump, crontab) run through `sudo -n` using the tightly scoped
# /etc/sudoers.d/librestack allowlist installed by scripts/install.sh. PHP-FPM
# itself must NEVER run as root. The installer sets this to true automatically.
LIBRESTACK_USE_SUDO=false

# Absolute path to the root-owned privileged-operation helper. The installer
# points this at the install directory; www-data may only sudo this one script.
LIBRESTACK_SAFE_OP_SCRIPT=/opt/librestack/scripts/librestack-safe-op

VITE_APP_NAME="${APP_NAME}"
